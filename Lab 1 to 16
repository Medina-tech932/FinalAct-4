<div class="box">
<h2>Lab 13: Simple Calculator</h2>

<form method="post">
    <input type="number" name="num1" placeholder="First Number">
    <input type="number" name="num2" placeholder="Second Number">
    <select name="operator">
        <option value="+">+</option>
        <option value="-">-</option>
        <option value="*">*</option>
        <option value="/">/</option>
    </select>
    <button type="submit" name="lab13">Calculate</button>
</form>

<div class="result">
<?php
if(isset($_POST['lab13'])){
    $a = $_POST['num1'];
    $b = $_POST['num2'];
    $op = $_POST['operator'];

    switch($op){
        case "+":
            echo $a + $b;
            break;

        case "-":
            echo $a - $b;
            break;

        case "*":
            echo $a * $b;
            break;

        case "/":
            if($b != 0){
                echo $a / $b;
            } else {
                echo "Cannot divide by zero";
            }
            break;
    }
}
?>
</div>
</div>

